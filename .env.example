# Required
SECRET_KEY=your-secret-key-here  # generate with: python3 -c "import secrets; print(secrets.token_hex(32))"

# Optional — password reset emails (leave blank to print reset links to the console instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Optional — override if running on a non-default host/port
APP_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000
